PORT=3000
HOST=127.0.0.1
ENABLE_SIMULATOR=true
ADMIN_TOKEN=
AUTH_ENCRYPTION_KEY=
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
# OAuth/OIDC dos clientes. Preencha as tres variaveis juntas; o segredo fica somente no servidor.
# Exemplo local de callback: http://localhost:3000/api/customer-auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=
CUSTOMER_SESSION_TTL_DAYS=30
EXPOSE_DEVELOPMENT_RESET_TOKEN=false
APP_ENV=development
VERIFY_TOKEN=
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
META_APP_SECRET=
GRAPH_API_VERSION=v23.0
# Somente dígitos, com país e DDD. Ex.: 5511999999999
STORE_WHATSAPP_NUMBER=
STORE_NAME=Surgery For Life
# Reservas abandonadas no site são liberadas; handoff confirmado mantém a baixa.
RESERVATION_TTL_MINUTES=30
STORE_TIMEZONE=America/Sao_Paulo
BUSINESS_HOURS=seg-sex 09:00-18:00; sab 09:00-13:00
DELIVERY_FEE=10.00
FREE_SHIPPING_FROM=200.00
